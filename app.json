{
  "expo": {
    "name": "Dynamic Tasks",
    "slug": "TaskReminder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Dynamic Tasks App Icon updated.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Dynamic Tasks App Icon updated.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abrahabe.dynamictasks",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.abrahabe.TaskReminder"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/Dynamic Tasks App Icon updated.png",
          "color": "#7C6FE0",
          "androidMode": "default"
        }
      ]
    ]
  }
}
